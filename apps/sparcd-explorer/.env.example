# Copy to .env and fill in. .env is gitignored.

# --- SPARC'd S3 / MinIO (image collections, uploads) ---
# Endpoint is HOST[:PORT] only — no scheme. Set SECURE=true for https.
SPARCD_S3_ENDPOINT=s3.example.org
SPARCD_S3_ACCESS_KEY=
SPARCD_S3_SECRET_KEY=
SPARCD_S3_SECURE=true
# Optional: restrict the preview to a single bucket. Leave blank to list all.
SPARCD_S3_BUCKET=

# --- SPARC'd SQLite (app state DB; optional) ---
# Path to a local copy of the sparcd.sqlite file. Leave blank to skip.
SPARCD_DB=
